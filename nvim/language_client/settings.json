{
    "pyls": {
        "plugins": {
            "pyflakes": {
                "enabled": true
            },
            "pydocstyle": {
                "enabled": false
            },
            "pycodestyle": {
                "enabled": false
            },
            "flake8": {
                "enabled": true
            }
        }
    },
    "yaml": {
        "format": {
            "enable": false
        },
        "completion": true,
        "validate": true,
        "schemas": {
            "AWS CloudFormation Serverless Application Model (SAM)": "/*"
        }
    },
    "http": {
        "proxyStrictSSL": true
    }
}
