{
    "pyls": {
        "plugins": {
            "pyflakes": {
                "enabled": true
            },
            "pydocstyle": {
                "enabled": false
            },
            "pycodestyle": {
                "enabled": false
            },
            "flake8": {
                "enabled": false
            }
        }
    },
    "yaml": {
        "format": {
            "enable": false
        },
        "validate": true
    },
    "http": {
        "proxyStrictSSL": true
    }
}
