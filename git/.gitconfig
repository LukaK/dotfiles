[user]
	email = luka.krapic@gmail.com
	name = Luka Krapic
[alias]
	co = checkout
	st = status
	ci = commit
	br = branch
	a = add
    mg = merge
	g = git
[push]
	default = matching
[core]
	excludesfile = ~/.config/git/gitignore_global
	pager = less -F
[merge]
	ff = true
[commit]
	template = ~/dotfiles/git/git_message
